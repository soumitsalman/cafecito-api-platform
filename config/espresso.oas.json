            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Signal"
                  }
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "204": {
            "description": "no matching signals"
          },
          "400": {
            "description": "invalid query parameters or malformed UUID in ids",
            "content": {
              "application/json": {
                "schema": {
