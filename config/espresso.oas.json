{
  "info": {
    "title": "Espresso API & MCP",
    "description": "Espresso is a curated business intelligence product suite. Espresso API & MCP provides access to the underlying data store.\nA **sip** is the basic unit of information: action (micro data such as market performance for a day), event (a self-contained set of micro actions and actions), and signal (larger derived intelligence from related events and actions).\nAll sip identifiers are UUIDs (RFC 4122), for example `339366bc-464d-582f-8132-6875ccc814d2`. Pass them as strings in query parameters and path segments.\nList endpoints accept an optional `response_type` query parameter: `json` (default) or `text`. Both return the same underlying data; `text` renders it as flat plain text without JSON syntax, which reduces token cost for MCPs and AI agents.",
    "version": "0.1",
    "contact": {
      "name": "Project Cafecito",
      "url": "http://cafecito.tech",
      "email": "soumitsrah@cafecito.tech"
    },
    "license": {
      "name": "MIT"
    }
  },
  "openapi": "3.1.0",
  "tags": [
    {
      "name": "Events",
      "description": "Event-kind sips \u2014 self-contained digests of micro actions and developments"
    },
    {
      "name": "Signals",
      "description": "Signal-kind sips \u2014 derived intelligence synthesized from related events and actions"
    },
    {
      "name": "Related",
      "description": "Sips linked to source UUIDs through same_as or derived_from relationships"
    },
    {
      "name": "Tags",
      "description": "Unique tag strings for filtering events and signals"
    },
    {
      "name": "Health",
      "description": "Service health and liveness endpoints"
    },
    {
      "name": "General",
      "description": "Infrastructure endpoints"
    }
  ],
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "title": "Error",
            "description": "Human-readable error message.",
            "example": "invalid id: not-a-uuid"
          }
        },
        "required": [
          "error"
        ],
        "title": "ErrorResponse",
        "description": "Standard JSON error envelope for 4xx and 5xx responses."
      },
      "Event": {
        "type": "object",
        "title": "Event",
        "description": "Flattened JSON shape returned for event-kind sips. The handler merges persisted sip metadata (`id`, `reported`) into the digest before responding. Individual records may include additional pipeline-specific keys not listed here.",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id",
            "description": "Sip UUID (RFC 4122).",
            "example": "091726f8-421a-566d-9db8-339625f2ed9e"
          },
          "reported": {
            "type": "string",
            "format": "date-time",
            "title": "Reported",
            "description": "Reported timestamp of the sip (maps from persisted created).",
            "example": "2026-06-28T22:49:07Z"
          },
          "briefing": {
            "type": "string",
            "title": "Briefing",
            "description": "Concise summary of the event.",
            "example": "On June 28, 2026, three U.S. firefighters died while battling rapidly spreading wildfires near the Colorado-Utah border; approximately 100 sq km burned. Temperatures reached 34°C with strong winds, prompting mass evacuations. The Snyder Fire merged with others, causing significant damage to infrastructure like ski resorts. Causes include severe drought and human factors. This incident reflects escalating regional wildfire risks driven by climate change."
          },
          "event_type": {
            "type": "string",
            "title": "Event Type",
            "description": "Category or classification of the event.",
            "example": "wildfire_outbreak"
          },
          "impact_level": {
            "type": "string",
            "title": "Impact Level",
            "description": "Assessed impact severity.",
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "example": "high"
          },
          "future_outlook": {
            "type": "string",
            "title": "Future Outlook",
            "description": "Forward-looking assessment of likely developments.",
            "example": "Continued extreme fire seasons expected without mitigation efforts."
          },
          "actions": {
            "type": "array",
            "title": "Actions",
            "description": "Micro actions or developments that compose the event.",
            "items": {
              "type": "string"
            },
            "example": [
              "2026-06-28 Firefighters died and injuries occurred at Wyoming-Utah border.",
              "2026-06-28 Large wildfire destroyed parts of ski resorts."
            ]
          },
          "cross_domain_impacts": {
            "type": "array",
            "title": "Cross Domain Impacts",
            "description": "Effects spanning multiple domains or sectors.",
            "items": {
              "type": "string"
            },
            "example": [
              "public_safety: Increased risk of civilian casualties.",
              "tourism: Disruption of winter sports facilities.",
              "environmental: Habitat loss in mountainous areas."
            ]
          },
          "companies": {
            "type": "array",
            "title": "Companies",
            "description": "Companies or organizations associated with the event.",
            "items": {
              "type": "string"
            },
            "example": [
              "us_federal",
              "us_state"
            ]
          },
          "products": {
            "type": "array",
            "title": "Products",
            "description": "Products or commodities associated with the event.",
            "items": {
              "type": "string"
            },
            "example": [
              "petróleo"
            ]
          },
          "macro_context": {
            "type": "string",
            "title": "Macro Context",
            "description": "Broader macroeconomic or geopolitical context for the event.",
            "example": "western_us_climate_crisis"
          },
          "people": {
            "type": "array",
            "title": "People",
            "description": "People mentioned or involved in the event.",
            "items": {
              "type": "string"
            },
            "example": [
              "firefighter_john_doe",
              "governor_polis"
            ]
          },
          "regions": {
            "type": "array",
            "title": "Regions",
            "description": "Geographic regions associated with the event.",
            "items": {
              "type": "string"
            },
            "example": [
              "colorado",
              "utah"
            ]
          },
          "tags": {
            "type": "array",
            "title": "Tags",
            "description": "Scalar tags for filtering and discovery.",
            "items": {
              "type": "string"
            },
            "example": [
              "wildfire",
              "climate_change",
              "us",
              "emergency_response"
            ]
          }
        }
      },
      "Signal": {
        "type": "object",
        "title": "Signal",
        "description": "Flattened JSON shape returned for signal-kind sips. The handler merges persisted sip metadata (`id`, `reported`) into the digest before responding. Individual records may include additional pipeline-specific keys not listed here.",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id",
            "description": "Sip UUID (RFC 4122).",
            "example": "e7d7571a-13f0-56f0-8563-50863b79c781"
          },
          "reported": {
            "type": "string",
            "format": "date-time",
            "title": "Reported",
            "description": "Reported timestamp of the sip (maps from persisted created).",
            "example": "2026-06-02T14:02:00-04:00"
          },
          "briefing": {
            "type": "string",
            "title": "Briefing",
            "description": "Concise summary of the signal.",
            "example": "On 2026-06-02, U.S. lawmakers and the Trump administration debated AI sovereign-wealth and compute-tax proposals amid soaring inflation..."
          },
          "impact_level": {
            "type": "string",
            "title": "Impact Level",
            "description": "Assessed impact severity.",
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "example": "high"
          },
          "forecast": {
            "type": "string",
            "title": "Forecast",
            "description": "Forward-looking outlook synthesized from related events.",
            "example": "Short-term: Market volatility will persist, AI regulatory scrutiny will intensify, and consumer confidence remains low."
          },
          "events": {
            "type": "array",
            "title": "Events",
            "description": "Related events that contributed to this signal.",
            "items": {
              "type": "string"
            },
            "example": [
              "2026-06-01: Senator Bernie Sanders introduced a 50% ownership tax on major AI firms"
            ]
          },
          "impacts": {
            "type": "array",
            "title": "Impacts",
            "description": "Observed or projected impacts.",
            "items": {
              "type": "string"
            },
            "example": [
              "9.3% market sell-off across tech and financial sectors.",
              "Decline in consumer confidence and increased credit-card delinquency."
            ]
          },
          "drivers": {
            "type": "array",
            "title": "Drivers",
            "description": "Underlying drivers or catalysts.",
            "items": {
              "type": "string"
            },
            "example": [
              "High inflation and rising consumer costs driven by supply-chain bottlenecks and geopolitical tensions."
            ]
          },
          "impacted_domains": {
            "type": "array",
            "title": "Impacted Domains",
            "description": "Business or policy domains affected by the signal.",
            "items": {
              "type": "string"
            },
            "example": [
              "finance",
              "technology",
              "cybersecurity",
              "labor",
              "healthcare",
              "energy",
              "policy"
            ]
          },
          "tags": {
            "type": "array",
            "title": "Tags",
            "description": "Scalar tags for filtering and discovery.",
            "items": {
              "type": "string"
            },
            "example": [
              "ai_sovereign_wealth_fund",
              "ai_taxation",
              "compute_tax",
              "inflation",
              "market_volatility"
            ]
          }
        }
      }
    }
  },
  "paths": {
    "/espresso/health": {
      "get": {
        "summary": "Check API health",
        "description": "Lightweight liveness probe. Use before other tools to confirm the service is reachable. No authentication required when API keys are disabled.",
        "tags": [
          "Health"
        ],
        "responses": {
          "200": {
            "description": "status alive",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "alive"
                    }
                  }
                }
              }
            }
          }
        },
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlRewriteHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "rewritePattern": "${env.ESPRESSO_BASE_URL}/health"
            }
          },
          "policies": {
            "inbound": [
              "infra-rate-limit-inbound",
              "backend-api-key-inbound"
            ]
          }
        },
        "operationId": "healthCheck"
      }
    },
    "/espresso/events": {
      "get": {
        "summary": "Search events",
        "description": "Returns event-kind sips sorted by `created` descending (newest first).\nWith `response_type=text`, each event is rendered as a flat plain-text digest (field-per-line) instead of a JSON object \u2014 same data, fewer tokens for MCPs and AI agents.",
        "tags": [
          "Events"
        ],
        "parameters": [
          {
            "name": "ids",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uuid"
              },
              "title": "Ids"
            },
            "style": "form",
            "explode": false,
            "description": "fetch specific event sips by UUID (RFC 4122), e.g. 339366bc-464d-582f-8132-6875ccc814d2"
          },
          {
            "name": "tags",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "title": "Tags"
            },
            "style": "form",
            "explode": false,
            "description": "scalar tag filters (inclusive AND across supplied tags)"
          },
          {
            "name": "q",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "maxLength": 1024,
              "title": "Q"
            },
            "description": "semantic search query (max 1024 characters; requires embedder)"
          },
          {
            "name": "acc",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "maximum": 1,
              "minimum": 0,
              "default": 0.75,
              "title": "Acc"
            },
            "description": "minimum embedding similarity for `q` (0.0-1.0, higher = stricter)"
          },
          {
            "name": "from",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date",
              "title": "From"
            },
            "description": "include events created on or after this date (YYYY-MM-DD)"
          },
          {
            "name": "response_type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "text"
              ],
              "default": "json",
              "title": "Response Type"
            },
            "description": "output format: json (default) returns a JSON array of flattened digests; text returns the same data as flat plain text without JSON syntax (lower token cost for MCPs and AI agents)"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 128,
              "minimum": 1,
              "default": 16,
              "title": "Limit"
            },
            "description": "page size"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "title": "Offset"
            },
            "description": "pagination offset"
          }
        ],
        "responses": {
          "200": {
            "description": "JSON array of flattened event digests when response_type=json (default); plain-text event digests when response_type=text",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Event"
                  }
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "204": {
            "description": "no matching events"
          },
          "400": {
            "description": "invalid query parameters or malformed UUID in ids",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "database or embedder error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlRewriteHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "rewritePattern": "${env.ESPRESSO_BASE_URL}/events"
            }
          },
          "policies": {
            "inbound": [
              "zuplo-api-key-inbound",
              "freeuser-rate-limit-inbound",
              "freeuser-quota-inbound",
              "backend-api-key-inbound"
            ]
          }
        },
        "operationId": "searchEvents"
      }
    },
    "/espresso/signals": {
      "get": {
        "summary": "Search signals",
        "description": "Returns signal-kind sips sorted by `created` descending (newest first).\nWith `response_type=text`, each signal is rendered as a flat plain-text digest (field-per-line) instead of a JSON object \u2014 same data, fewer tokens for MCPs and AI agents.",
        "tags": [
