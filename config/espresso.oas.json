                }
              }
            }
          }
        },
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlRewriteHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "rewritePattern": "${env.ESPRESSO_BASE_URL}/signals"
            }
          },
          "policies": {
            "inbound": [
              "zuplo-api-key-inbound",
              "freeuser-rate-limit-inbound",
