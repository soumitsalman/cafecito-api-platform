    "/espresso/related/{relationship}": {
      "get": {
        "summary": "List related sips",
        "description": "Returns sips linked to the supplied UUIDs through the requested relationship. With `response_type=text`, each related sip is rendered as a flat plain-text digest (field-per-line) instead of a JSON object — same data, fewer tokens for MCPs and AI agents.",
        "tags": [
          "Related"
        ],
        "parameters": [
          {
            "name": "relationship",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "same_as",
                "derived_from"
              ],
              "title": "Relationship"
            },
            "description": "Relationship to traverse"
          },
          {
            "name": "ids",
            "in": "query",
            "required": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uuid"
              },
              "title": "Ids"
            },
            "style": "form",
            "explode": false,
            "description": "Source sip UUIDs (RFC 4122), e.g. b07049b5-54c0-50b0-a620-d3aea3f8a173"
          },
          {
            "name": "response_type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "text"
              ],
              "default": "json",
              "title": "Response Type"
            },
            "description": "Output format: json (default) returns a JSON array of flattened digests; text returns the same data as flat plain text without JSON syntax (lower token cost for MCPs and AI agents)"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 128,
              "minimum": 1,
              "default": 16,
              "title": "Limit"
            },
            "description": "Page size"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "title": "Offset"
            },
            "description": "Pagination offset"
          }
        ],
        "responses": {
          "200": {
            "description": "JSON array of flattened related-sip digests when response_type=json (default); plain-text related-sip digests when response_type=text",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "oneOf": [
                      {
                        "$ref": "#/components/schemas/Event"
                      },
                      {
                        "$ref": "#/components/schemas/Signal"
                      }
                    ]
                  }
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "204": {
            "description": "No related sips found"
          },
          "400": {
            "description": "Missing ids, invalid relationship, or malformed UUID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Database error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlRewriteHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "rewritePattern": "${env.ESPRESSO_BASE_URL}/related/${params.relationship}"
            }
          },
          "policies": {
            "inbound": [
              "zuplo-api-key-inbound",
              "freeuser-rate-limit-inbound",
              "freeuser-quota-inbound",
              "backend-api-key-inbound"
            ]
          }
        },
        "operationId": "listEspressoRelatedSips"
      }
    }
  }
