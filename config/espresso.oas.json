            ]
          }
        },
        "operationId": "searchSignals"
      }
    },
    "/espresso/tags": {
      "get": {
        "summary": "List tags for filtering events and signals",
        "description": "Returns a paginated, alphabetically sorted list of unique tag strings extracted from event and signal sips. Tags can be passed to `/espresso/events` and `/espresso/signals` for scalar filtering.\nWith `response_type=text`, tags are returned as a single comma-separated plain-text string instead of a JSON array.",
        "tags": [
          "Tags"
        ],
        "parameters": [
          {
            "name": "response_type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "text"
              ],
              "default": "json",
              "title": "Response Type"
            },
            "description": "output format: json (default) returns a JSON string array; text returns the same tags as comma-separated plain text (lower token cost for MCPs and AI agents)"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 128,
              "minimum": 1,
              "default": 16,
              "title": "Limit"
            },
            "description": "page limit (items per page)"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "title": "Offset"
            },
            "description": "pagination offset (number of items to skip)"
          }
        ],
        "responses": {
          "200": {
            "description": "JSON string array when response_type=json (default); comma-separated tags when response_type=text",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "204": {
            "description": "no matching tags"
          },
          "400": {
            "description": "invalid pagination parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "database error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlRewriteHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "rewritePattern": "${env.ESPRESSO_BASE_URL}/tags"
            }
          },
          "policies": {
            "inbound": [
              "zuplo-api-key-inbound",
              "freeuser-rate-limit-inbound",
              "freeuser-quota-inbound",
              "backend-api-key-inbound"
            ]
          }
        },
        "operationId": "listTags"
      }
    },
    "/espresso/related/{relationship}": {
      "get": {
        "summary": "Get related sips by relationship",
        "description": "Returns sips linked to the supplied UUIDs through the requested relationship.\nWith `response_type=text`, each related sip is rendered as a flat plain-text digest (field-per-line) instead of a JSON object \u2014 same data, fewer tokens for MCPs and AI agents.",
        "tags": [
          "Related"
        ],
        "parameters": [
          {
            "name": "relationship",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "same_as",
                "derived_from"
              ],
              "title": "Relationship"
            },
            "description": "relationship to traverse"
          },
          {
            "name": "ids",
            "in": "query",
            "required": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uuid"
              },
              "title": "Ids"
            },
            "style": "form",
            "explode": false,
            "description": "source sip UUIDs (RFC 4122), e.g. b07049b5-54c0-50b0-a620-d3aea3f8a173"
          },
          {
            "name": "response_type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "text"
              ],
              "default": "json",
              "title": "Response Type"
            },
            "description": "output format: json (default) returns a JSON array of flattened digests; text returns the same data as flat plain text without JSON syntax (lower token cost for MCPs and AI agents)"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 128,
              "minimum": 1,
              "default": 16,
              "title": "Limit"
            },
            "description": "page size"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "title": "Offset"
            },
            "description": "pagination offset"
          }
        ],
        "responses": {
          "200": {
            "description": "JSON array of flattened related-sip digests when response_type=json (default); plain-text related-sip digests when response_type=text",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "oneOf": [
                      {
                        "$ref": "#/components/schemas/Event"
                      },
                      {
                        "$ref": "#/components/schemas/Signal"
                      }
                    ]
                  }
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "204": {
            "description": "no related sips found"
          },
          "400": {
            "description": "missing ids, invalid relationship, or malformed UUID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "database error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlRewriteHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "rewritePattern": "${env.ESPRESSO_BASE_URL}/related/${params.relationship}"
            }
          },
          "policies": {
            "inbound": [
              "zuplo-api-key-inbound",
              "freeuser-rate-limit-inbound",
              "freeuser-quota-inbound",
              "backend-api-key-inbound"
            ]
          }
        },
        "operationId": "getRelatedSips"
      }
    },
    "/espresso/mcp": {
      "post": {
        "summary": "Espresso MCP server",
        "description": "Model Context Protocol (MCP) endpoint for the Espresso service. Exposes Espresso tools to MCP-compatible clients such as AI agents and LLM-powered applications.",
        "tags": [
          "General"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JSON-RPC response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "mcpServerHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "name": "cafecito-espresso-mcp",
              "version": "0.1",
              "operations": [
                "searchEvents",
                "searchSignals",
                "listTags",
                "getRelatedSips"
              ]
            }
          },
          "policies": {
            "inbound": [
              "zuplo-api-key-inbound",
              "gate-auth"
            ]
          }
        },
        "operationId": "espressoMcp"
      }
    }
  }
}
